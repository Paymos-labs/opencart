<div class="d-grid">
  <button type="button" id="button-paymos" class="btn btn-primary">{{ button_confirm }}</button>
</div>
<script>
document.getElementById('button-paymos').addEventListener('click', function () {
  var button = this;
  button.disabled = true;

  fetch('{{ action }}', {method: 'POST', headers: {'X-Requested-With': 'XMLHttpRequest'}})
    .then(function (response) { return response.json(); })
    .then(function (json) {
      if (json.error) {
        alert(json.error);
        button.disabled = false;
        return;
      }

      if (json.redirect) {
        window.location.href = json.redirect;
      }
    })
    .catch(function () {
      button.disabled = false;
    });
});
</script>
